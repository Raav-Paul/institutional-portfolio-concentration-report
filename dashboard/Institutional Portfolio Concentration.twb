      <column caption='Allocation Bucket' datatype='real' name='[Calculation_0124798021165060]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [position_bucket (bucket_summary_clean)] :&#13;&#10;AVG([capital_percentage (bucket_summary_clean)])&#13;&#10;}' />
      </column>
      <column caption='diversification indicator' datatype='string' name='[Calculation_0252896762761218]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([effective_holdings]) &gt; 35.68 THEN&#13;&#10;&quot;☑   Diversified&quot;&#13;&#10;ELSE&#13;&#10;&quot;☒   Not Diversified&quot;&#13;&#10;END' />
      </column>
      <column caption='concentration indicator' datatype='string' name='[Calculation_0252896765325315]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([top5_concentration]) &gt; 0.5 THEN&#13;&#10;&quot;☒   High Concentration&quot;&#13;&#10;ELSE&#13;&#10;&quot;☑  Balanced&quot;&#13;&#10;END' />
